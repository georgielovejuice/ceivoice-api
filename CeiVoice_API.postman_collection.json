                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"name\": \"Test User\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/login",
