    {
      "name": "🔐 Authentication",
      "item": [
        {
          "name": "Register New User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "  let response = pm.response.json();",
                  "  pm.environment.set('user_id', response.user.user_id);",
                  "  pm.environment.set('user_email', response.user.email);",
                  "  pm.test('Registration successful', () => {",
                  "    pm.expect(response.user.email).to.include('@');",
                  "  });",
                  "  console.log('✓ User registered. ID: ' + response.user.user_id);",
                  "} else {",
                  "  pm.test('Registration failed', () => {",
                  "    pm.expect(pm.response.code).to.equal(201);",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Test User\",\n  \"email\": \"testuser{{$timestamp}}@example.com\",\n  \"password\": \"TestPass123!\",\n  \"confirmPassword\": \"TestPass123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  let response = pm.response.json();",
                  "  pm.environment.set('access_token', response.accessToken);",
                  "  pm.environment.set('refresh_token', response.refreshToken);",
                  "  pm.environment.set('user_id', response.user.user_id);",
                  "  pm.test('Login successful', () => {",
                  "    pm.expect(response.accessToken).to.be.truthy;",
                  "  });",
                  "  console.log('✓ Login successful. Token saved.');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"your-password\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
