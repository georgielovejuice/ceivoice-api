{
  "name": "ceivoice-api-backend",
  "version": "1.0.0",
  "description": "CeiVoice API Backend - Merged TypeScript Express.js Application",
  "main": "dist/server.ts",
  "scripts": {
    "dev": "pnpm exec nodemon --watch src --ext ts,json --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:prod": "pnpm run build && pnpm start",
    "worker:email": "node dist/workers/email.worker.js",
    "worker:email:dev": "npx nodemon --exec ts-node src/workers/email.worker.ts",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node prisma/seed.ts",
    "deploy": "pnpm install && pnpm build && pm2 restart ceivoice-api"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/georgielovejuice/test-ceivoice-backend-database.git"
  },
  "keywords": [
    "express",
    "typescript",
    "prisma",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/georgielovejuice/test-ceivoice-backend-database/issues"
  },
  "homepage": "https://github.com/georgielovejuice/test-ceivoice-backend-database#readme",
  "dependencies": {
    "@prisma/client": "^6.19.1",
    "@react-email/components": "^1.0.8",
    "@react-email/render": "^0.0.12",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.97.0",
    "axios": "^1.6.5",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "email-validator": "^2.0.4",
    "express": "^5.2.1",
    "google-auth-library": "^10.5.0",
    "googleapis": "^118.0.0",
    "jsonwebtoken": "^9.0.3",
    "ollama": "^0.6.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "resend": "^3.0.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.43",
    "@types/uuid": "^9.0.6",
    "nodemon": "^3.1.11",
    "prisma": "^6.19.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
