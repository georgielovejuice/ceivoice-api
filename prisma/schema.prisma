generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["public", "auth"]
}

model TicketStatus {
  status_id          Int             @id @default(autoincrement())
  name               String          @unique @db.VarChar(20)
  step_order         Int             @unique
  description        String?
  is_active          Boolean         @default(true)
  status_history     StatusHistory[] @relation("NewStatus")
  old_status_history StatusHistory[] @relation("OldStatus")
  tickets            Ticket[]

  @@index([step_order])
  @@map("ticket_statuses")
  @@schema("public")
}

model Category {
  category_id Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(50)
  sla_hours   Int      @default(24)
  description String?
  is_active   Boolean  @default(true)
  tickets     Ticket[]

  @@index([name])
  @@map("categories")
  @@schema("public")
}

model User {
  user_id              String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                String              @unique @db.VarChar(255)
  full_name            String?
  user_name            String?
  role                 String              @db.VarChar(20)
  is_active            Boolean             @default(true)
  onboarding_completed Boolean             @default(false)
  created_at           DateTime            @default(now()) @db.Timestamptz(6)
  updated_at           DateTime            @default(now()) @updatedAt @db.Timestamptz(6)
  scopes               AssigneeScope[]
  assignment_changes   AssignmentHistory[] @relation("AssignmentChangedBy")
  new_assignments      AssignmentHistory[] @relation("NewAssignee")
  old_assignments      AssignmentHistory[] @relation("OldAssignee")
  comments             Comment[]
  followers            Follower[]
  notifications        Notification[]
  status_changes       StatusHistory[]     @relation("StatusChangedBy")
  ticket_activations   Ticket[]            @relation("TicketActivatedBy")
  assigned_tickets     Ticket[]            @relation("CurrentAssignee")
  created_tickets      Ticket[]            @relation("TicketCreator")

  @@index([email])
  @@index([role])
  @@index([is_active])
  @@map("users")
  @@schema("public")
}

model Request {
  request_id      Int             @id @default(autoincrement())
  email           String          @db.VarChar(255)
  message         String
  tracking_id     String          @unique @default(cuid())
  created_at      DateTime        @default(now())
  ticket_requests TicketRequest[]

  @@index([email])
  @@index([tracking_id])
  @@index([created_at])
  @@map("requests")
  @@schema("public")
}

model Ticket {
  ticket_id             Int                 @id @default(autoincrement())
  title                 String              @db.VarChar(150)
  summary               String
  suggested_solution    String?
  status_id             Int?
  category_id           Int?
  creator_user_id       String?             @db.Uuid
  assignee_user_id      String?             @db.Uuid
  parent_ticket_id      Int?
  created_at            DateTime            @default(now())
  activated_at          DateTime?
  activated_by_id       String?             @db.Uuid
  deadline              DateTime?
  resolved_at           DateTime?
  updated_at            DateTime            @updatedAt
  resolution_comment_id Int?
  priority              String              @default("Medium") @db.VarChar(10)
  assignment_history    AssignmentHistory[]
  comments              Comment[]           @relation("TicketComments")
  followers             Follower[]
  notifications         Notification[]
  status_history        StatusHistory[]
  ticket_requests       TicketRequest[]
  activated_by          User?               @relation("TicketActivatedBy", fields: [activated_by_id], references: [user_id])
  assignee              User?               @relation("CurrentAssignee", fields: [assignee_user_id], references: [user_id])
  category              Category?           @relation(fields: [category_id], references: [category_id])
  creator               User?               @relation("TicketCreator", fields: [creator_user_id], references: [user_id])
  resolution_comment    Comment?            @relation("ResolutionComment", fields: [resolution_comment_id], references: [comment_id])
  status                TicketStatus?       @relation(fields: [status_id], references: [status_id])
  parent_ticket         Ticket?             @relation("MergedTickets", fields: [parent_ticket_id], references: [ticket_id], onDelete: SetNull)
  child_tickets         Ticket[]            @relation("MergedTickets")

  @@index([status_id])
  @@index([category_id])
  @@index([assignee_user_id])
  @@index([creator_user_id])
  @@index([activated_at])
  @@index([deadline])
  @@index([created_at])
  @@index([priority])
  @@index([parent_ticket_id])
  @@map("tickets")
  @@schema("public")
}

model StatusHistory {
  history_id    Int           @id @default(autoincrement())
  ticket_id     Int
  old_status_id Int?
  new_status_id Int?
  changed_by_id String?       @db.Uuid
  change_reason String?
  changed_at    DateTime      @default(now())
  changed_by    User?         @relation("StatusChangedBy", fields: [changed_by_id], references: [user_id])
  new_status    TicketStatus? @relation("NewStatus", fields: [new_status_id], references: [status_id])
  old_status    TicketStatus? @relation("OldStatus", fields: [old_status_id], references: [status_id])
  ticket        Ticket        @relation(fields: [ticket_id], references: [ticket_id], onDelete: Cascade)

  @@index([ticket_id])
  @@index([new_status_id])
  @@index([changed_at])
  @@index([changed_by_id])
  @@map("status_histories")
  @@schema("public")
}

model AssignmentHistory {
  assignment_id   Int      @id @default(autoincrement())
  ticket_id       Int
  old_assignee_id String?  @db.Uuid
  new_assignee_id String?  @db.Uuid
  changed_by_id   String   @db.Uuid
  change_reason   String?
  changed_at      DateTime @default(now())
  changed_by      User     @relation("AssignmentChangedBy", fields: [changed_by_id], references: [user_id])
  new_assignee    User?    @relation("NewAssignee", fields: [new_assignee_id], references: [user_id])
  old_assignee    User?    @relation("OldAssignee", fields: [old_assignee_id], references: [user_id])
  ticket          Ticket   @relation(fields: [ticket_id], references: [ticket_id], onDelete: Cascade)

  @@index([ticket_id])
  @@index([new_assignee_id])
  @@index([changed_at])
  @@map("assignment_histories")
  @@schema("public")
}

model Comment {
  comment_id            Int      @id @default(autoincrement())
  ticket_id             Int
  user_id               String   @db.Uuid
  content               String
  visibility            String   @default("PUBLIC") @db.VarChar(10)
  created_at            DateTime @default(now())
  ticket                Ticket   @relation("TicketComments", fields: [ticket_id], references: [ticket_id], onDelete: Cascade)
  user                  User     @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  resolution_for_ticket Ticket[] @relation("ResolutionComment")

  @@index([ticket_id])
  @@index([user_id])
  @@index([created_at])
  @@index([visibility])
  @@map("comments")
  @@schema("public")
}

model Follower {
  follower_id Int      @id @default(autoincrement())
  ticket_id   Int
  user_id     String   @db.Uuid
  followed_at DateTime @default(now())
  ticket      Ticket   @relation(fields: [ticket_id], references: [ticket_id], onDelete: Cascade)
  user        User     @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@unique([ticket_id, user_id])
  @@index([ticket_id])
  @@index([user_id])
  @@map("followers")
  @@schema("public")
}

model TicketRequest {
  ticket_id  Int
  request_id Int
  request    Request @relation(fields: [request_id], references: [request_id], onDelete: Cascade)
  ticket     Ticket  @relation(fields: [ticket_id], references: [ticket_id], onDelete: Cascade)

  @@id([ticket_id, request_id])
  @@index([ticket_id])
  @@index([request_id])
  @@map("ticket_requests")
  @@schema("public")
}

model AssigneeScope {
  scope_id    Int    @id @default(autoincrement())
  assignee_id String @db.Uuid
  scope_name  String @db.VarChar(50)
  assignee    User   @relation(fields: [assignee_id], references: [user_id], onDelete: Cascade)

  @@unique([assignee_id, scope_name])
  @@index([assignee_id])
  @@index([scope_name])
  @@map("assignee_scopes")
  @@schema("public")
}

model Notification {
  notification_id Int      @id @default(autoincrement())
  ticket_id       Int
  user_id         String   @db.Uuid
  type            String   @db.VarChar(30)
  message         String
  is_read         Boolean  @default(false)
  created_at      DateTime @default(now())
  ticket          Ticket   @relation(fields: [ticket_id], references: [ticket_id], onDelete: Cascade)
  user            User     @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@index([ticket_id])
  @@index([user_id])
  @@index([is_read])
  @@index([created_at])
  @@map("notifications")
  @@schema("public")
}

model OauthToken {
  token_id      Int       @id @default(autoincrement())
  user_id       String    @unique @db.Uuid
  google_token  String
  refresh_token String?
  expires_at    DateTime?

  @@map("oauth_tokens")
  @@schema("public")
}
