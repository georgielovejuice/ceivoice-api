generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/**
 * ===== MODELS START HERE =====
 */

model User {
  user_id    Int      @id @default(autoincrement())
  email      String   @unique
  name       String?
  role       String   @default("USER")
  created_at DateTime @default(now())

  comments      Comment[]
  statusChanges StatusHistory[] @relation("StatusChangedBy")

  assignmentOld AssignmentHistory[] @relation("OldAssignee")
  assignmentNew AssignmentHistory[] @relation("NewAssignee")
}

model Request {
  request_id Int      @id @default(autoincrement())
  email      String
  message    String
  created_at DateTime @default(now())

  ticketRequests TicketRequest[]
}

model Ticket {
  ticket_id          Int       @id @default(autoincrement())
  title              String    @db.VarChar(100)
  summary            String    @db.VarChar(500)
  suggested_solution String
  status             String
  deadline           DateTime?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  category_id Int
  category    Category @relation(fields: [category_id], references: [category_id])

  comments          Comment[]
  statusHistory     StatusHistory[]
  ticketRequests    TicketRequest[]
  assignmentHistory AssignmentHistory[]
}

model Category {
  category_id Int    @id @default(autoincrement())
  name        String @unique

  tickets Ticket[]
}

model Comment {
  comment_id  Int      @id @default(autoincrement())
  content     String
  is_internal Boolean
  created_at  DateTime @default(now())

  ticket_id Int
  user_id   Int

  ticket Ticket @relation(fields: [ticket_id], references: [ticket_id])
  user   User   @relation(fields: [user_id], references: [user_id])
}

model StatusHistory {
  history_id Int      @id @default(autoincrement())
  old_status String
  new_status String
  changed_at DateTime @default(now())

  ticket_id  Int
  changed_by Int

  ticket Ticket @relation(fields: [ticket_id], references: [ticket_id])
  user   User   @relation("StatusChangedBy", fields: [changed_by], references: [user_id])
}

model TicketRequest {
  ticket_id  Int
  request_id Int

  ticket  Ticket  @relation(fields: [ticket_id], references: [ticket_id])
  request Request @relation(fields: [request_id], references: [request_id])

  @@id([ticket_id, request_id])
}

model AssignmentHistory {
  assignment_id   Int      @id @default(autoincrement())
  ticket_id       Int
  old_assignee_id Int?
  new_assignee_id Int
  changed_at      DateTime @default(now())

  ticket Ticket @relation(fields: [ticket_id], references: [ticket_id])

  oldAssignee User? @relation("OldAssignee", fields: [old_assignee_id], references: [user_id])
  newAssignee User  @relation("NewAssignee", fields: [new_assignee_id], references: [user_id])
}


