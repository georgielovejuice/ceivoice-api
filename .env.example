# Database (Prisma / Supabase Postgres)
# Pooler URL — used at runtime (Transaction mode pooler URL from Supabase)
DATABASE_URL="your-pooler-database-url-here"
# Direct URL — used by Prisma migrations (direct connection URL from Supabase)
DIRECT_URL="your-direct-database-url-here"

# Server
PORT=5000
NODE_ENV=production
# CORS: set to your Vercel frontend URL in production
CORS_ORIGIN=https://your-app.vercel.app

# Authentication Mode
# "DEV" skips Google OAuth verification | "PRODUCTION" enforces it
AUTH_MODE=PRODUCTION

# Email (via Resend — https://resend.com)
RESEND_API_KEY="re_your_api_key_here"
DISABLE_EMAIL=false
FROM_EMAIL="noreply@yourdomain.com"
# Set to your Vercel deployment URL in production
FRONTEND_URL="https://your-app.vercel.app"

# Supabase (Settings → API in Supabase dashboard)
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key-here"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key-here"
SUPABASE_JWT_SECRET="your-supabase-jwt-secret-here"
# Must match a Redirect URL registered in Supabase → Auth → URL Configuration
# Development: http://localhost:5000/api/auth/google/callback
# Production:  https://api.yourdomain.com/api/auth/google/callback
SUPABASE_OAUTH_CALLBACK_URL="https://api.yourdomain.com/api/auth/google/callback"

# RabbitMQ — not used in production path; set false to disable
RABBITMQ_ENABLED=false
RABBITMQ_URL="amqp://localhost:5672"

# AI / Ollama — in production docker-compose this is overridden to http://ollama:11434
OLLAMA_HOST="http://localhost:11434"
OLLAMA_MODEL="ceivoice-ai"
