# Database (Prisma)
# Pooler URL — used at runtime
DATABASE_URL="your-pooler-database-url-here"
# Direct URL — used by Prisma migrations
DIRECT_URL="your-direct-database-url-here"

# Server
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Authentication Mode
# "DEV" skips Google OAuth verification | "PRODUCTION" enforces it
AUTH_MODE=DEV

# Email (via Resend — https://resend.com)
RESEND_API_KEY="re_your_api_key_here"
DISABLE_EMAIL=false   # set to true to suppress all outbound emails (dev/testing)
FROM_EMAIL="noreply@yourdomain.com"
FRONTEND_URL="http://localhost:3000"

# Supabase (Settings → API in Supabase dashboard)
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key-here"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key-here"
SUPABASE_JWT_SECRET="your-supabase-jwt-secret-here"
# Must match a Redirect URL registered in Supabase → Auth → URL Configuration
SUPABASE_OAUTH_CALLBACK_URL="http://localhost:5000/api/auth/google/callback"

# RabbitMQ (set RABBITMQ_ENABLED=false to disable)
RABBITMQ_ENABLED=false
RABBITMQ_URL="amqp://localhost:5672"

# AI / Ollama
OLLAMA_HOST="http://localhost:11434"
OLLAMA_MODEL="ceivoice-ai"
