generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  user_id            Int                 @id @default(autoincrement())
  email              String              @unique
  name               String?
  password           String?
  role               String              @default("USER")
  google_id          String?             @unique
  google_email       String?
  is_assignee        Boolean             @default(false)
  created_at         DateTime            @default(now())
  updated_at         DateTime            @updatedAt
  scopes             AssigneeScope[]
  assignment_new     AssignmentHistory[] @relation("NewAssignee")
  assignment_old     AssignmentHistory[] @relation("OldAssignee")
  comments           Comment[]
  followers          Follower[]          @relation("FollowerUser")
  notifications      Notification[]
  oauth_tokens       OAuthToken?
  status_changes     StatusHistory[]     @relation("StatusChangedBy")
  ticket_assignments TicketAssignment[]

  @@index([email])
  @@index([is_assignee])
  @@map("users")
}

model OAuthToken {
  token_id      Int       @id @default(autoincrement())
  user_id       Int       @unique
  google_token  String
  refresh_token String?
  expires_at    DateTime?
  user          User      @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@map("oauth_tokens")
}

model Request {
  request_id      Int             @id @default(autoincrement())
  email           String
  message         String
  tracking_id     String          @unique @default(cuid())
  created_at      DateTime        @default(now())
  ticket_requests TicketRequest[]

  @@index([email])
  @@index([tracking_id])
  @@map("requests")
}

model Ticket {
  ticket_id            Int                 @id @default(autoincrement())
  title                String              @db.VarChar(100)
  summary              String              @db.VarChar(500)
  suggested_solution   String?             @db.VarChar(1000)
  status               String              @default("Draft")
  deadline             DateTime?
  created_at           DateTime            @default(now())
  updated_at           DateTime            @updatedAt
  category_id          Int?
  assignment_histories AssignmentHistory[]
  comments             Comment[]
  followers            Follower[]
  notifications        Notification[]
  status_history       StatusHistory[]
  assignments          TicketAssignment[]
  ticket_requests      TicketRequest[]
  category             Category?           @relation(fields: [category_id], references: [category_id])

  @@index([status])
  @@index([deadline])
  @@index([category_id])
  @@index([created_at])
  @@map("tickets")
}

model Category {
  category_id Int      @id @default(autoincrement())
  name        String   @unique
  tickets     Ticket[]

  @@map("categories")
}

model TicketAssignment {
  assignment_id Int      @id @default(autoincrement())
  ticket_id     Int
  assignee_id   Int
  assigned_at   DateTime @default(now())
  is_active     Boolean  @default(true)
  assignee      User     @relation(fields: [assignee_id], references: [user_id], onDelete: Cascade)
  ticket        Ticket   @relation(fields: [ticket_id], references: [ticket_id], onDelete: Cascade)

  @@unique([ticket_id, assignee_id])
  @@index([assignee_id])
  @@index([ticket_id])
  @@map("ticket_assignments")
}

model Follower {
  follower_id Int      @id @default(autoincrement())
  ticket_id   Int
  user_id     Int
  followed_at DateTime @default(now())
  ticket      Ticket   @relation(fields: [ticket_id], references: [ticket_id], onDelete: Cascade)
  user        User     @relation("FollowerUser", fields: [user_id], references: [user_id], onDelete: Cascade)

  @@unique([ticket_id, user_id])
  @@index([ticket_id])
  @@index([user_id])
  @@map("followers")
}

model Comment {
  comment_id  Int      @id @default(autoincrement())
  content     String
  is_internal Boolean  @default(false)
  created_at  DateTime @default(now())
  ticket_id   Int
  user_id     Int
  ticket      Ticket   @relation(fields: [ticket_id], references: [ticket_id], onDelete: Cascade)
  user        User     @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@index([ticket_id])
  @@index([user_id])
  @@index([created_at])
  @@map("comments")
}

model StatusHistory {
  history_id Int      @id @default(autoincrement())
  old_status String
  new_status String
  changed_at DateTime @default(now())
  ticket_id  Int
  changed_by Int
  user       User     @relation("StatusChangedBy", fields: [changed_by], references: [user_id], onDelete: Cascade)
  ticket     Ticket   @relation(fields: [ticket_id], references: [ticket_id], onDelete: Cascade)

  @@index([ticket_id])
  @@index([changed_by])
  @@index([changed_at])
  @@map("status_histories")
}

model AssignmentHistory {
  assignment_id   Int      @id @default(autoincrement())
  ticket_id       Int
  old_assignee_id Int?
  new_assignee_id Int?
  changed_at      DateTime @default(now())
  new_assignee    User?    @relation("NewAssignee", fields: [new_assignee_id], references: [user_id])
  old_assignee    User?    @relation("OldAssignee", fields: [old_assignee_id], references: [user_id])
  ticket          Ticket   @relation(fields: [ticket_id], references: [ticket_id], onDelete: Cascade)

  @@index([ticket_id])
  @@index([changed_at])
  @@map("assignment_histories")
}

model TicketRequest {
  ticket_id  Int
  request_id Int
  request    Request @relation(fields: [request_id], references: [request_id], onDelete: Cascade)
  ticket     Ticket  @relation(fields: [ticket_id], references: [ticket_id], onDelete: Cascade)

  @@id([ticket_id, request_id])
  @@index([ticket_id])
  @@index([request_id])
  @@map("ticket_requests")
}

model AssigneeScope {
  scope_id    Int    @id @default(autoincrement())
  assignee_id Int
  scope_name  String
  assignee    User   @relation(fields: [assignee_id], references: [user_id], onDelete: Cascade)

  @@unique([assignee_id, scope_name])
  @@index([assignee_id])
  @@map("assignee_scopes")
}

model Notification {
  notification_id Int      @id @default(autoincrement())
  ticket_id       Int
  user_id         Int
  type            String
  message         String
  is_read         Boolean  @default(false)
  created_at      DateTime @default(now())
  ticket          Ticket   @relation(fields: [ticket_id], references: [ticket_id], onDelete: Cascade)
  user            User     @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@index([ticket_id])
  @@index([user_id])
  @@index([is_read])
  @@index([created_at])
  @@map("notifications")
}
