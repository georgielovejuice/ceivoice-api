generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== LOOKUP TABLES (Reference Data) =====

model TicketStatus {
  status_id   Int     @id @default(autoincrement())
  name        String  @unique @db.VarChar(20) // Draft, New, Assigned, Solving, Solved, Failed, Renew
  step_order  Int     @unique // Defines workflow progression order
  description String?
  is_active   Boolean @default(true) // Soft delete flag for future status retirement

  // Relations
  tickets         Ticket[]
  status_history  StatusHistory[] @relation("NewStatus")
  old_status_history StatusHistory[] @relation("OldStatus")

  @@index([step_order])
  @@map("ticket_statuses")
}

enum ticket_status {
  Draft
  New
  Assigned
  Solving
  Solved
  Failed
  Renew
}

enum comment_visibility {
  Internal
  Public
}

// =======================
// MODELS
// =======================

model User {
  user_id   Int       @unique @default(autoincrement()) // Unique required for relations to work
  email     String
  full_name String?
  google_id String?
  avartar   String?   // Kept spelling from SQL
  role      user_role @default(User)

  // Relations
  created_tickets    Ticket[]            @relation("TicketCreator")
  assigned_tickets   TicketAssignment[]
  followed_tickets   TicketFollower[]
  comments           Comment[]
  audit_logs         AuditLog[]
  user_departments   UserDepartment[]

  @@id([user_id, email])
  @@map("users")
}

model Department {
  department       String           @id
  
  // Relations
  user_departments UserDepartment[]

  @@map("departments")
}

model Category {
  catagory String   @id // Kept spelling from SQL
  
  // Relations
  tickets  Ticket[]

  @@map("categories")
}

model Ticket {
  ticket_id          String        @id
  original_message   String
  title              String?
  summary            String?
  suggested_solution String?
  category_name      String?       @map("category") // Mapped to column 'category'
  status             ticket_status @default(Draft)
  deadline           DateTime?
  submission_time    DateTime?     @default(now())
  creator_id         Int?
  parent_ticket_id   String?

  // Relations
  category           Category?     @relation(fields: [category_name], references: [catagory])
  creator            User?         @relation("TicketCreator", fields: [creator_id], references: [user_id])
  
  // Self-Relation (Consolidation)
  parent_ticket      Ticket?       @relation("TicketConsolidation", fields: [parent_ticket_id], references: [ticket_id])
  child_tickets      Ticket[]      @relation("TicketConsolidation")

  // Junctions & Logs
  assignments        TicketAssignment[]
  followers          TicketFollower[]
  comments           Comment[]
  audit_logs         AuditLog[]

  @@map("tickets")
}

// =======================
// JUNCTION TABLES
// =======================

model UserDepartment {
  user_id         Int
  department_name String

  user       User       @relation(fields: [user_id], references: [user_id])
  department Department @relation(fields: [department_name], references: [department])

  @@id([user_id, department_name])
  @@map("user_departments")
}

model TicketAssignment {
  ticket_id   String
  assignee_id Int
  assigned_at DateTime? @default(now())

  ticket   Ticket @relation(fields: [ticket_id], references: [ticket_id])
  assignee User   @relation(fields: [assignee_id], references: [user_id])

  @@id([ticket_id, assignee_id])
  @@map("ticket_assignments")
}

model TicketFollower {
  ticket_id   String
  follower_id Int

  ticket   Ticket @relation(fields: [ticket_id], references: [ticket_id])
  follower User   @relation(fields: [follower_id], references: [user_id])

  @@id([ticket_id, follower_id])
  @@map("ticket_followers")
}

// =======================
// LOGS & COMMENTS
// =======================

model Comment {
  comment_id Int                @id @default(autoincrement())
  ticket_id  String?
  author_id  Int?
  content    String?
  visibility comment_visibility @default(Public)
  created_at DateTime?          @default(now())

  ticket Ticket? @relation(fields: [ticket_id], references: [ticket_id])
  author User?   @relation(fields: [author_id], references: [user_id])

  @@map("comments")
}

model AuditLog {
  log_id      Int       @id @default(autoincrement())
  ticket_id   String?
  actor_id    Int?
  action_type String?
  old_value   String?
  new_value   String?
  occurred_at DateTime? @default(now())

  ticket Ticket? @relation(fields: [ticket_id], references: [ticket_id])
  actor  User?   @relation(fields: [actor_id], references: [user_id])

  @@map("audit_logs")
}