# Database
DATABASE_URL="your-database-url-here"

# Server
PORT=5000
NODE_ENV=development

# JWT Authentication
# Signs access tokens (15 min lifetime)
JWT_SECRET="your-super-secret-jwt-key-change-this-to-something-long-and-secure"
# Signs refresh tokens (7 day lifetime) — different secret limits blast radius
JWT_REFRESH_SECRET="your-refresh-secret-key-change-this-to-something-long-and-secure"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id-here"
GOOGLE_CLIENT_SECRET="your-google-client-secret-here"
GOOGLE_REDIRECT_URI="http://localhost:3000/auth/callback"

# Email Configuration
EMAIL_SERVICE=gmail
EMAIL_USER="your-email@gmail.com"
EMAIL_PASSWORD="your-email-password"
FRONTEND_URL="http://localhost:3000"

# Authentication Mode
# Use "DEV" for development without Google OAuth verification
# Use "PRODUCTION" for real Google OAuth
AUTH_MODE=DEV
DEV_ROLE=ADMIN

# OAuth (if using Google OAuth service)
GOOGLE_REDIRECT_URI_OAUTH="http://localhost:5000/api/auth/google/callback"

SUPABASE_URL="your-supabase-url-here"

SUPABASE_ANON_KEY="your-supabase-anon-key-here"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key-here"
# Must match a Redirect URL registered in Supabase → Auth → URL Configuration
SUPABASE_OAUTH_CALLBACK_URL="http://localhost:5000/api/auth/google/callback"
